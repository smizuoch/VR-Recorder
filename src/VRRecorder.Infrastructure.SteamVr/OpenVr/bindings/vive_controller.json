{
  "action_manifest_version": 1,
  "bindings": {
    "/actions/vrrecorder": {
      "sources": [
        {
          "inputs": {
            "click": {
              "output": "/actions/vrrecorder/in/toggle_recording"
            }
          },
          "mode": "button",
          "path": "/user/hand/right/input/application_menu"
        },
        {
          "inputs": {
            "click": {
              "output": "/actions/vrrecorder/in/toggle_recording"
            }
          },
          "mode": "button",
          "path": "/user/hand/left/input/application_menu"
        },
        {
          "inputs": {
            "click": {
              "output": "/actions/vrrecorder/in/toggle_microphone"
            }
          },
          "mode": "button",
          "path": "/user/hand/left/input/grip"
        },
        {
          "inputs": {
            "click": {
              "output": "/actions/vrrecorder/in/recenter_overlay"
            }
          },
          "mode": "button",
          "path": "/user/hand/right/input/grip"
        }
      ]
    }
  },
  "controller_type": "vive_controller",
  "description": "Recommended VR-Recorder recording, microphone, and recenter bindings for Vive controllers",
  "name": "VR-Recorder Vive bindings"
}
