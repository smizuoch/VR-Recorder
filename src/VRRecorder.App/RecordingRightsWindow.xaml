<Window x:Class="VRRecorder.App.RecordingRightsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Rights_Title}"
        AutomationProperties.Name="{DynamicResource Rights_Title}"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
        FlowDirection="{DynamicResource Layout.FlowDirection}"
        MaxWidth="640"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="{StaticResource Spacing.LayoutGrid.Thickness}" MaxWidth="560">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Rights_Body}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{DynamicResource Rights_Body}" />

        <CheckBox x:Name="RightsAcknowledgementCheckBox"
                  Grid.Row="1"
                  Margin="{StaticResource Spacing.LayoutGrid.Top}"
                  MinHeight="{StaticResource Interaction.MinimumTarget}"
                  Content="{DynamicResource Rights_Acknowledge_Label}"
                  AutomationProperties.Name="{DynamicResource Rights_Acknowledge_AccessibleName}"
                  Checked="OnAcknowledgementChanged"
                  Unchecked="OnAcknowledgementChanged" />

        <StackPanel Grid.Row="2"
                    Margin="{StaticResource Spacing.LayoutGrid.Top}"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{DynamicResource Rights_Decline_Label}"
                    MinHeight="{StaticResource Interaction.MinimumTarget}"
                    AutomationProperties.Name="{DynamicResource Rights_Decline_AccessibleName}"
                    AutomationProperties.HelpText="{DynamicResource Rights_Decline_Tooltip}"
                    ToolTip="{DynamicResource Rights_Decline_Tooltip}"
                    IsCancel="True"
                    Click="OnDecline" />
            <Border Width="{StaticResource Spacing.LayoutGrid}" />
            <Button x:Name="AcceptRightsButton"
                    MinHeight="{StaticResource Interaction.MinimumTarget}"
                    Content="{DynamicResource Rights_Accept_Label}"
                    AutomationProperties.Name="{DynamicResource Rights_Accept_AccessibleName}"
                    AutomationProperties.HelpText="{DynamicResource Rights_Accept_Tooltip}"
                    ToolTip="{DynamicResource Rights_Accept_Tooltip}"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="OnAccept" />
        </StackPanel>
    </Grid>
</Window>
