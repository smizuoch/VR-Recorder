<Window x:Class="VRRecorder.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings_Title}"
        AutomationProperties.Name="{DynamicResource Settings_Title}"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
        FlowDirection="{DynamicResource Layout.FlowDirection}"
        Loaded="OnLoaded"
        Closed="OnClosed"
        Width="720"
        Height="760"
        MinWidth="560"
        MinHeight="480"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="{StaticResource Spacing.LayoutGrid.Thickness}">
            <TextBlock Text="{DynamicResource Settings_Intro}"
                       TextWrapping="Wrap" />

            <GroupBox Margin="{StaticResource Spacing.LayoutGrid.Top}"
                      Header="{DynamicResource Settings_Output_Heading}">
                <Grid Margin="{StaticResource Spacing.LayoutGrid.Thickness}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="{DynamicResource Settings_OutputFolder_Label}" />
                    <TextBox x:Name="OutputFolderTextBox"
                             Grid.Row="1"
                             Margin="{StaticResource Spacing.LayoutGrid.Top}"
                             MinHeight="{StaticResource Interaction.MinimumTarget}"
                             IsReadOnly="True"
                             AutomationProperties.Name="{DynamicResource Settings_OutputFolder_Label}"
                             AutomationProperties.HelpText="{DynamicResource Settings_OutputFolder_Tooltip}"
                             ToolTip="{DynamicResource Settings_OutputFolder_Tooltip}" />
                    <WrapPanel Grid.Row="2"
                               Margin="{StaticResource Spacing.LayoutGrid.Top}">
                        <Button x:Name="BrowseOutputFolderButton"
                                Margin="{StaticResource Spacing.LayoutGrid.Right}"
                                MinHeight="{StaticResource Interaction.MinimumTarget}"
                                MinWidth="{StaticResource Interaction.MinimumTarget}"
                                Content="{DynamicResource Settings_Output_Browse_Label}"
                                AutomationProperties.Name="{DynamicResource Settings_Output_Browse_AccessibleName}"
                                AutomationProperties.HelpText="{DynamicResource Settings_Output_Browse_Tooltip}"
                                ToolTip="{DynamicResource Settings_Output_Browse_Tooltip}"
                                IsEnabled="False"
                                Click="OnBrowseOutputFolder" />
                        <Button x:Name="UseDownloadsButton"
                                MinHeight="{StaticResource Interaction.MinimumTarget}"
                                MinWidth="{StaticResource Interaction.MinimumTarget}"
                                Content="{DynamicResource Settings_Output_Downloads_Label}"
                                AutomationProperties.Name="{DynamicResource Settings_Output_Downloads_AccessibleName}"
                                AutomationProperties.HelpText="{DynamicResource Settings_Output_Downloads_Tooltip}"
                                ToolTip="{DynamicResource Settings_Output_Downloads_Tooltip}"
                                IsEnabled="False"
                                Click="OnUseDownloads" />
                    </WrapPanel>
                </Grid>
            </GroupBox>

            <GroupBox Margin="{StaticResource Spacing.LayoutGrid.Top}"
                      Header="{DynamicResource Settings_Language_Label}">
                <ComboBox x:Name="UiLocaleComboBox"
                          Margin="{StaticResource Spacing.LayoutGrid.Thickness}"
                          MinHeight="{StaticResource Interaction.MinimumTarget}"
                          DisplayMemberPath="Label"
                          SelectionChanged="OnSelectionChanged"
                          AutomationProperties.Name="{DynamicResource Settings_Language_Label}"
                          AutomationProperties.HelpText="{DynamicResource Settings_Language_Tooltip}"
                          ToolTip="{DynamicResource Settings_Language_Tooltip}" />
            </GroupBox>

            <GroupBox Margin="{StaticResource Spacing.LayoutGrid.Top}"
                      Header="{DynamicResource Settings_Recording_Heading}">
                <Grid Margin="{StaticResource Spacing.LayoutGrid.Thickness}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="{StaticResource Spacing.LayoutGrid}" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Settings_SelfTimer_Label}" />
                    <ComboBox x:Name="SelfTimerComboBox"
                              Grid.Row="0"
                              Grid.Column="2"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              DisplayMemberPath="Label"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_SelfTimer_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_SelfTimer_Tooltip}"
                              ToolTip="{DynamicResource Settings_SelfTimer_Tooltip}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Settings_AutoStop_Label}" />
                    <ComboBox x:Name="AutoStopComboBox"
                              Grid.Row="1"
                              Grid.Column="2"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              DisplayMemberPath="Label"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_AutoStop_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_AutoStop_Tooltip}"
                              ToolTip="{DynamicResource Settings_AutoStop_Tooltip}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Settings_FrameRate_Label}" />
                    <ComboBox x:Name="FrameRateComboBox"
                              Grid.Row="2"
                              Grid.Column="2"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              DisplayMemberPath="Label"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_FrameRate_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_FrameRate_Tooltip}"
                              ToolTip="{DynamicResource Settings_FrameRate_Tooltip}" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Settings_ResolutionPolicy_Label}" />
                    <ComboBox x:Name="ResolutionPolicyComboBox"
                              Grid.Row="3"
                              Grid.Column="2"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              DisplayMemberPath="Label"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_ResolutionPolicy_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_ResolutionPolicy_Tooltip}"
                              ToolTip="{DynamicResource Settings_ResolutionPolicy_Tooltip}" />

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Settings_Encoder_Label}" />
                    <ComboBox x:Name="EncoderComboBox"
                              Grid.Row="4"
                              Grid.Column="2"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              DisplayMemberPath="Label"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_Encoder_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_Encoder_Tooltip}"
                              ToolTip="{DynamicResource Settings_Encoder_Tooltip}" />

                    <TextBlock Grid.Row="5"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Settings_Quality_Label}" />
                    <ComboBox x:Name="QualityPresetComboBox"
                              Grid.Row="5"
                              Grid.Column="2"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              DisplayMemberPath="Label"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_Quality_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_Quality_Tooltip}"
                              ToolTip="{DynamicResource Settings_Quality_Tooltip}" />
                </Grid>
            </GroupBox>

            <GroupBox Margin="{StaticResource Spacing.LayoutGrid.Top}"
                      Header="{DynamicResource Settings_Audio_Heading}">
                <StackPanel Margin="{StaticResource Spacing.LayoutGrid.Thickness}">
                    <TextBlock Text="{DynamicResource Settings_DesktopEndpoint_Label}" />
                    <ComboBox x:Name="DesktopEndpointComboBox"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              IsEditable="True"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_DesktopEndpoint_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_DesktopEndpoint_Tooltip}"
                              ToolTip="{DynamicResource Settings_DesktopEndpoint_Tooltip}" />

                    <TextBlock Margin="{StaticResource Spacing.LayoutGrid.Top}"
                               Text="{DynamicResource Settings_MicrophoneEndpoint_Label}" />
                    <ComboBox x:Name="MicrophoneEndpointComboBox"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              IsEditable="True"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_MicrophoneEndpoint_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_MicrophoneEndpoint_Tooltip}"
                              ToolTip="{DynamicResource Settings_MicrophoneEndpoint_Tooltip}" />

                    <TextBlock Text="{DynamicResource Settings_AudioRouting_Label}" />
                    <ComboBox x:Name="AudioRoutingComboBox"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              DisplayMemberPath="Label"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_AudioRouting_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_AudioRouting_Tooltip}"
                              ToolTip="{DynamicResource Settings_AudioRouting_Tooltip}" />

                    <DockPanel Margin="{StaticResource Spacing.LayoutGrid.Top}">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{DynamicResource Settings_DesktopGain_Label}" />
                        <TextBlock x:Name="DesktopGainValueText"
                                   HorizontalAlignment="Right" />
                    </DockPanel>
                    <Slider x:Name="DesktopGainSlider"
                            MinHeight="{StaticResource Interaction.MinimumTarget}"
                            Minimum="-96"
                            Maximum="24"
                            SmallChange="1"
                            LargeChange="6"
                            TickFrequency="6"
                            ValueChanged="OnGainChanged"
                            AutomationProperties.Name="{DynamicResource Settings_DesktopGain_Label}"
                            AutomationProperties.HelpText="{DynamicResource Settings_DesktopGain_Tooltip}"
                            ToolTip="{DynamicResource Settings_DesktopGain_Tooltip}" />

                    <DockPanel Margin="{StaticResource Spacing.LayoutGrid.Top}">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{DynamicResource Settings_MicrophoneGain_Label}" />
                        <TextBlock x:Name="MicrophoneGainValueText"
                                   HorizontalAlignment="Right" />
                    </DockPanel>
                    <Slider x:Name="MicrophoneGainSlider"
                            MinHeight="{StaticResource Interaction.MinimumTarget}"
                            Minimum="-96"
                            Maximum="24"
                            SmallChange="1"
                            LargeChange="6"
                            TickFrequency="6"
                            ValueChanged="OnGainChanged"
                            AutomationProperties.Name="{DynamicResource Settings_MicrophoneGain_Label}"
                            AutomationProperties.HelpText="{DynamicResource Settings_MicrophoneGain_Tooltip}"
                            ToolTip="{DynamicResource Settings_MicrophoneGain_Tooltip}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Margin="{StaticResource Spacing.LayoutGrid.Top}"
                      Header="{DynamicResource Settings_Vr_Heading}">
                <StackPanel Margin="{StaticResource Spacing.LayoutGrid.Thickness}">
                    <TextBlock Text="{DynamicResource Settings_VrHand_Label}" />
                    <ComboBox x:Name="VrHandComboBox"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              DisplayMemberPath="Label"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_VrHand_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_VrHand_Tooltip}"
                              ToolTip="{DynamicResource Settings_VrHand_Tooltip}" />
                    <TextBlock Margin="{StaticResource Spacing.LayoutGrid.Top}"
                               Text="{DynamicResource Settings_OverlayPlacement_Label}" />
                    <ComboBox x:Name="OverlayPlacementComboBox"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              DisplayMemberPath="Label"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_OverlayPlacement_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_OverlayPlacement_Tooltip}"
                              ToolTip="{DynamicResource Settings_OverlayPlacement_Tooltip}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Margin="{StaticResource Spacing.LayoutGrid.Top}"
                      Header="{DynamicResource Settings_Osc_Heading}">
                <StackPanel Margin="{StaticResource Spacing.LayoutGrid.Thickness}">
                    <TextBlock Text="{DynamicResource Settings_OscAutoDiscover_Label}" />
                    <ComboBox x:Name="OscAutoDiscoverComboBox"
                              Margin="{StaticResource Spacing.LayoutGrid.Top}"
                              MinHeight="{StaticResource Interaction.MinimumTarget}"
                              DisplayMemberPath="Label"
                              SelectionChanged="OnSelectionChanged"
                              AutomationProperties.Name="{DynamicResource Settings_OscAutoDiscover_Label}"
                              AutomationProperties.HelpText="{DynamicResource Settings_OscAutoDiscover_Tooltip}"
                              ToolTip="{DynamicResource Settings_OscAutoDiscover_Tooltip}" />
                    <TextBlock Margin="{StaticResource Spacing.LayoutGrid.Top}"
                               Text="{DynamicResource Settings_OscFallbackHost_Label}" />
                    <TextBox x:Name="OscFallbackHostTextBox"
                             MinHeight="{StaticResource Interaction.MinimumTarget}"
                             TextChanged="OnSettingsTextChanged"
                             AutomationProperties.Name="{DynamicResource Settings_OscFallbackHost_Label}"
                             AutomationProperties.HelpText="{DynamicResource Settings_OscFallbackHost_Tooltip}"
                             ToolTip="{DynamicResource Settings_OscFallbackHost_Tooltip}" />
                    <TextBlock Margin="{StaticResource Spacing.LayoutGrid.Top}"
                               Text="{DynamicResource Settings_OscFallbackSendPort_Label}" />
                    <TextBox x:Name="OscFallbackSendPortTextBox"
                             MinHeight="{StaticResource Interaction.MinimumTarget}"
                             TextChanged="OnSettingsTextChanged"
                             AutomationProperties.Name="{DynamicResource Settings_OscFallbackSendPort_Label}"
                             AutomationProperties.HelpText="{DynamicResource Settings_OscFallbackSendPort_Label}" />
                    <TextBlock Margin="{StaticResource Spacing.LayoutGrid.Top}"
                               Text="{DynamicResource Settings_OscFallbackReceivePort_Label}" />
                    <TextBox x:Name="OscFallbackReceivePortTextBox"
                             MinHeight="{StaticResource Interaction.MinimumTarget}"
                             TextChanged="OnSettingsTextChanged"
                             AutomationProperties.Name="{DynamicResource Settings_OscFallbackReceivePort_Label}"
                             AutomationProperties.HelpText="{DynamicResource Settings_OscFallbackReceivePort_Label}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Margin="{StaticResource Spacing.LayoutGrid.Top}"
                      Header="{DynamicResource Settings_Rights_Heading}">
                <TextBlock Margin="{StaticResource Spacing.LayoutGrid.Thickness}"
                           Text="{DynamicResource Rights_Body}"
                           TextWrapping="Wrap"
                           AutomationProperties.Name="{DynamicResource Rights_Body}" />
            </GroupBox>

            <TextBlock x:Name="SettingsStatusText"
                       Margin="{StaticResource Spacing.LayoutGrid.Top}"
                       TextWrapping="Wrap"
                       AutomationProperties.LiveSetting="Assertive" />

            <StackPanel Margin="{StaticResource Spacing.LayoutGrid.Top}"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="{DynamicResource Settings_Cancel_Label}"
                        MinHeight="{StaticResource Interaction.MinimumTarget}"
                        MinWidth="{StaticResource Interaction.MinimumTarget}"
                        AutomationProperties.Name="{DynamicResource Settings_Cancel_AccessibleName}"
                        AutomationProperties.HelpText="{DynamicResource Settings_Cancel_Tooltip}"
                        ToolTip="{DynamicResource Settings_Cancel_Tooltip}"
                        Click="OnCancel" />
                <Border Width="{StaticResource Spacing.LayoutGrid}" />
                <Button x:Name="SaveSettingsButton"
                        Content="{DynamicResource Settings_Save_Label}"
                        MinHeight="{StaticResource Interaction.MinimumTarget}"
                        MinWidth="{StaticResource Interaction.MinimumTarget}"
                        AutomationProperties.Name="{DynamicResource Settings_Save_AccessibleName}"
                        AutomationProperties.HelpText="{DynamicResource Settings_Save_Tooltip}"
                        ToolTip="{DynamicResource Settings_Save_Tooltip}"
                        IsDefault="True"
                        IsEnabled="False"
                        Click="OnSave" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
