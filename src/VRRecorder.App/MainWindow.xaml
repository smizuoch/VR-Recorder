<Window x:Class="VRRecorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource App_Title}"
        AutomationProperties.Name="{DynamicResource App_Window_AccessibleName}"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
        FlowDirection="{DynamicResource Layout.FlowDirection}"
        Closing="OnClosing"
        Loaded="OnLoaded"
        PreviewKeyDown="OnPreviewKeyDown"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="{StaticResource Spacing.LayoutGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="RecordingStatusText"
                   Grid.Row="0"
                   Text="{DynamicResource Recording_State_Booting}"
                   AutomationProperties.Name="{DynamicResource Status_Booting_AccessibleDescription}"
                   AutomationProperties.LiveSetting="Polite" />

        <TextBlock x:Name="RecordingSavedText"
                   Grid.Row="1"
                   Margin="0,{StaticResource Spacing.LayoutGrid},0,0"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   AutomationProperties.LiveSetting="Polite" />

        <TextBlock x:Name="CameraRestoreWarningText"
                   Grid.Row="2"
                   Margin="0,{StaticResource Spacing.LayoutGrid},0,0"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   AutomationProperties.LiveSetting="Assertive" />

        <Button x:Name="RecordingToggleButton"
                Grid.Row="3"
                Margin="0,{StaticResource Spacing.LayoutGrid},0,0"
                MinHeight="{StaticResource Interaction.MinimumTarget}"
                MinWidth="{StaticResource Interaction.MinimumTarget}"
                Content="{DynamicResource Recording_Start_Short}"
                AutomationProperties.Name="{DynamicResource Recording_Start_AccessibleName}"
                AutomationProperties.HelpText="{DynamicResource Recording_Start_Tooltip}"
                ToolTip="{DynamicResource Recording_Start_Tooltip}"
                IsEnabled="False"
                Click="OnRecordingToggleClick" />

        <Button x:Name="SettingsButton"
                Grid.Row="4"
                Margin="0,{StaticResource Spacing.LayoutGrid},0,0"
                MinHeight="{StaticResource Interaction.MinimumTarget}"
                MinWidth="{StaticResource Interaction.MinimumTarget}"
                Content="{DynamicResource Settings_Open_Label}"
                AutomationProperties.Name="{DynamicResource Settings_Open_AccessibleName}"
                AutomationProperties.HelpText="{DynamicResource Settings_Open_Tooltip}"
                ToolTip="{DynamicResource Settings_Open_Tooltip}"
                Click="OnSettingsClick" />

        <Button x:Name="DiagnosticsButton"
                Grid.Row="5"
                Margin="0,{StaticResource Spacing.LayoutGrid},0,0"
                MinHeight="{StaticResource Interaction.MinimumTarget}"
                MinWidth="{StaticResource Interaction.MinimumTarget}"
                Content="{DynamicResource Diagnostics_Open_Label}"
                AutomationProperties.Name="{DynamicResource Diagnostics_Open_AccessibleName}"
                AutomationProperties.HelpText="{DynamicResource Diagnostics_Open_Tooltip}"
                ToolTip="{DynamicResource Diagnostics_Open_Tooltip}"
                Click="OnDiagnosticsClick" />

        <Button x:Name="AboutLegalButton"
                Grid.Row="6"
                Margin="0,{StaticResource Spacing.LayoutGrid},0,0"
                MinHeight="{StaticResource Interaction.MinimumTarget}"
                MinWidth="{StaticResource Interaction.MinimumTarget}"
                Content="{DynamicResource Legal_Open_Label}"
                AutomationProperties.Name="{DynamicResource Legal_Open_AccessibleName}"
                AutomationProperties.HelpText="{DynamicResource Legal_Open_Tooltip}"
                ToolTip="{DynamicResource Legal_Open_Tooltip}"
                Click="OnAboutLegalClick" />
    </Grid>
</Window>
