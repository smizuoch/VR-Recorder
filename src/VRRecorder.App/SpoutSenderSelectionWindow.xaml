<Window x:Class="VRRecorder.App.SpoutSenderSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Spout_Selection_Title}"
        AutomationProperties.Name="{DynamicResource Spout_Selection_Title}"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
        FlowDirection="{DynamicResource Layout.FlowDirection}"
        MinWidth="520"
        MaxWidth="820"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="{StaticResource Spacing.LayoutGrid}"
          MaxWidth="780">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Spout_Selection_Body}"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="{DynamicResource Spout_Selection_Body}" />

        <ListBox x:Name="SpoutSenderList"
                 Grid.Row="1"
                 Margin="0,{StaticResource Spacing.LayoutGrid},0,0"
                 MinHeight="144"
                 MaxHeight="360"
                 DisplayMemberPath="Label"
                 SelectionChanged="OnSelectionChanged"
                 AutomationProperties.Name="{DynamicResource Spout_Selection_List_AccessibleName}"
                 AutomationProperties.HelpText="{DynamicResource Spout_Selection_List_Tooltip}"
                 ToolTip="{DynamicResource Spout_Selection_List_Tooltip}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="MinHeight"
                            Value="{StaticResource Interaction.MinimumTarget}" />
                    <Setter Property="VerticalContentAlignment"
                            Value="Center" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Grid.Row="2"
                    Margin="0,{StaticResource Spacing.LayoutGrid},0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{DynamicResource Spout_Selection_Cancel_Label}"
                    MinHeight="{StaticResource Interaction.MinimumTarget}"
                    MinWidth="{StaticResource Interaction.MinimumTarget}"
                    AutomationProperties.Name="{DynamicResource Spout_Selection_Cancel_AccessibleName}"
                    AutomationProperties.HelpText="{DynamicResource Spout_Selection_Cancel_Tooltip}"
                    ToolTip="{DynamicResource Spout_Selection_Cancel_Tooltip}"
                    IsCancel="True"
                    Click="OnCancel" />
            <Border Width="{StaticResource Spacing.LayoutGrid}" />
            <Button x:Name="AcceptSelectionButton"
                    Content="{DynamicResource Spout_Selection_Accept_Label}"
                    MinHeight="{StaticResource Interaction.MinimumTarget}"
                    MinWidth="{StaticResource Interaction.MinimumTarget}"
                    AutomationProperties.Name="{DynamicResource Spout_Selection_Accept_AccessibleName}"
                    AutomationProperties.HelpText="{DynamicResource Spout_Selection_Accept_Tooltip}"
                    ToolTip="{DynamicResource Spout_Selection_Accept_Tooltip}"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="OnAccept" />
        </StackPanel>
    </Grid>
</Window>
