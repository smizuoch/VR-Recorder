<Window x:Class="VRRecorder.App.FirstRunSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Setup_Window_Title}"
        AutomationProperties.Name="{DynamicResource Setup_Window_AccessibleName}"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
        FlowDirection="{DynamicResource Layout.FlowDirection}"
        Loaded="OnLoaded"
        MaxWidth="720"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="{StaticResource Spacing.LayoutGrid.Thickness}" MaxWidth="640">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="SetupProgressText"
                   Grid.Row="0"
                   AutomationProperties.LiveSetting="Polite"
                   AutomationProperties.Name="{DynamicResource Setup_Progress_AccessibleName}" />

        <ProgressBar x:Name="SetupProgressBar"
                     Grid.Row="1"
                     Margin="{StaticResource Spacing.ContentGap.Top}"
                     Height="8"
                     Minimum="0"
                     Maximum="100"
                     IsTabStop="False"
                     AutomationProperties.Name="{DynamicResource Setup_Progress_AccessibleName}" />

        <TextBlock x:Name="SetupTitleText"
                   Grid.Row="2"
                   Margin="{StaticResource Spacing.LayoutGrid.Top}"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   AutomationProperties.LiveSetting="Polite" />

        <TextBlock x:Name="SetupBodyText"
                   Grid.Row="3"
                   Margin="{StaticResource Spacing.ContentGap.Top}"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="4"
                    Margin="{StaticResource Spacing.LayoutGrid.Top}">
            <TextBlock Text="{DynamicResource Setup_VerificationPending}"
                       TextWrapping="Wrap"
                       AutomationProperties.Name="{DynamicResource Setup_VerificationPending}" />
            <TextBlock x:Name="SetupVerificationStatusText"
                       Margin="{StaticResource Spacing.ContentGap.Top}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       AutomationProperties.LiveSetting="Assertive" />
            <StackPanel Margin="{StaticResource Spacing.ContentGap.Top}"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button MinHeight="{StaticResource Interaction.MinimumTarget}"
                        MinWidth="{StaticResource Interaction.MinimumTarget}"
                        Content="{DynamicResource Setup_Settings_Label}"
                        AutomationProperties.Name="{DynamicResource Setup_Settings_AccessibleName}"
                        AutomationProperties.HelpText="{DynamicResource Setup_Settings_Tooltip}"
                        ToolTip="{DynamicResource Setup_Settings_Tooltip}"
                        Click="OnOpenSettings" />
                <Border Width="{StaticResource Spacing.LayoutGrid}" />
                <Button x:Name="VerifySetupButton"
                        MinHeight="{StaticResource Interaction.MinimumTarget}"
                        MinWidth="{StaticResource Interaction.MinimumTarget}"
                        Content="{DynamicResource Setup_Verify_Label}"
                        AutomationProperties.Name="{DynamicResource Setup_Verify_AccessibleName}"
                        AutomationProperties.HelpText="{DynamicResource Setup_Verify_Tooltip}"
                        ToolTip="{DynamicResource Setup_Verify_Tooltip}"
                        IsDefault="True"
                        Click="OnVerify" />
                <Border Width="{StaticResource Spacing.LayoutGrid}" />
                <Button MinHeight="{StaticResource Interaction.MinimumTarget}"
                        MinWidth="{StaticResource Interaction.MinimumTarget}"
                        Content="{DynamicResource Setup_Close_Label}"
                        AutomationProperties.Name="{DynamicResource Setup_Close_AccessibleName}"
                        AutomationProperties.HelpText="{DynamicResource Setup_Close_Tooltip}"
                        ToolTip="{DynamicResource Setup_Close_Tooltip}"
                        IsCancel="True"
                        Click="OnClose" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
