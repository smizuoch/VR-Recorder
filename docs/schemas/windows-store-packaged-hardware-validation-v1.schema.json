{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vr-recorder.invalid/schemas/windows-store-packaged-hardware-validation-v1.schema.json",
  "title": "VR Recorder Store Packaged Hardware Validation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "matrixProfile",
    "packageSha256",
    "runs"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "matrixProfile": {
      "const": "store-packaged-hardware-validation-v1"
    },
    "packageSha256": { "$ref": "#/$defs/sha256" },
    "runs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/run" }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "safeText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runId",
        "capturedAtUtc",
        "environment",
        "cases"
      ],
      "properties": {
        "runId": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "capturedAtUtc": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "environment": { "$ref": "#/$defs/environment" },
        "cases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": { "$ref": "#/$defs/case" }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "gpu", "driver", "steamVr", "hmd"],
      "properties": {
        "os": { "$ref": "#/$defs/safeText" },
        "gpu": { "$ref": "#/$defs/safeText" },
        "driver": { "$ref": "#/$defs/safeText" },
        "steamVr": { "$ref": "#/$defs/safeText" },
        "hmd": { "$ref": "#/$defs/safeText" }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caseId", "status", "artifacts"],
      "properties": {
        "caseId": { "$ref": "#/$defs/safeText" },
        "status": {
          "enum": ["passed", "failed", "blocked"]
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "$ref": "#/$defs/artifact" }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relativePath", "sha256"],
      "properties": {
        "relativePath": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
        },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
