{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vr-recorder:third-party-components:2",
  "title": "VR-Recorder Third Party Components v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleId",
    "productVersion",
    "generatedAtUtc",
    "integrityManifest",
    "components"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "bundleId": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "productVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "integrityManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "algorithm"],
      "properties": {
        "path": {
          "const": "LEGAL-MANIFEST.sha256"
        },
        "algorithm": {
          "const": "SHA-256"
        }
      }
    },
    "components": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "displayName",
          "version",
          "licenseExpression",
          "usage",
          "linkage",
          "modified",
          "licenseText",
          "sourceInfo"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "licenseExpression": {
            "type": "string",
            "minLength": 1
          },
          "usage": {
            "type": "string",
            "minLength": 1
          },
          "linkage": {
            "type": "string",
            "minLength": 1
          },
          "modified": {
            "type": "boolean"
          },
          "licenseText": {
            "type": "string",
            "minLength": 1
          },
          "sourceInfo": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
