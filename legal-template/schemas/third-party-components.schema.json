{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vr-recorder:third-party-components:1",
  "title": "VR-Recorder Third Party Components",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleId",
    "productVersion",
    "manifestSha256",
    "components"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "documentStatus": {
      "type": "string"
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "productVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedAtUtc": {
      "type": "string"
    },
    "manifestSha256": {
      "type": "string",
      "minLength": 1
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "displayName",
          "version",
          "licenseExpression",
          "licenseText"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "licenseExpression": {
            "type": "string",
            "minLength": 1
          },
          "licenseText": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
